{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"types": ["bun-types"],
		"jsx": "react-jsx",
		"jsxImportSource": "@opentui/react",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"paths": {
			"@adlr/sdk": ["../../packages/sdk/src/index.ts"],
			"@adlr/tui": ["../../packages/tui/src/index.ts"]
		}
	},
	"include": ["src/**/*", "test/**/*"],
	"exclude": ["../sdk/**/*", "../tui/**/*", "../daemon/**/*"]
}
