{
	"name": "adler",
	"private": true,
	"workspaces": {
		"packages": [
			"packages/*",
			"packages/plugins/*"
		],
		"catalog": {
			"@typescript/native-preview": "latest"
		}
	},
	"scripts": {
		"test": "bun test",
		"adler": "bun run packages/cli/src/index.ts",
		"lint": "bun run --filter='*' lint",
		"typecheck": "bun run --filter='*' typecheck"
	},
	"devDependencies": {
		"@adler/sdk": "workspace:*",
		"@biomejs/biome": "2.5.0",
		"@types/node": "^20.0.0",
		"@types/react": "^18.3.0",
		"typescript": "^5.5.0"
	}
}
